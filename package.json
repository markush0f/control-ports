{
  "name": "control-ports",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "api": "powershell -ExecutionPolicy Bypass -File scripts/run-vcvars.ps1 cargo run -p control-ports-api --manifest-path src-tauri/Cargo.toml",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "powershell -ExecutionPolicy Bypass -File scripts/run-vcvars.ps1 npx tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
